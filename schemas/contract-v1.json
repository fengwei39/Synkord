{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://synkord.dev/schema/contract-v1.json",
  "title": "Synkord Contract Pack v1",
  "type": "object",
  "required": ["pack", "version", "entities"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "pack": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Contract pack identifier, kebab-case"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version, e.g. 1.0.0"
    },
    "conventions": {
      "$ref": "#/$defs/Conventions"
    },
    "entities": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/Entity"
      },
      "minProperties": 1
    }
  },
  "$defs": {
    "Conventions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id_type": {
          "type": "string",
          "enum": ["uuid", "int", "string"]
        },
        "naming": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "db":   { "type": "string", "enum": ["snake_case", "camelCase", "PascalCase"] },
            "api":  { "type": "string", "enum": ["snake_case", "camelCase", "PascalCase"] },
            "java": { "type": "string", "enum": ["snake_case", "camelCase", "PascalCase"] },
            "go":   { "type": "string", "enum": ["snake_case", "camelCase", "PascalCase"] }
          }
        },
        "timestamps": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "Entity": {
      "type": "object",
      "required": ["table", "fields"],
      "additionalProperties": false,
      "properties": {
        "table": { "type": "string" },
        "fields": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/Field" },
          "minProperties": 1
        },
        "relations": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/Relation" }
        }
      }
    },
    "Field": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["uuid", "string", "int", "boolean", "datetime", "enum", "json"]
        },
        "primary":   { "type": "boolean" },
        "unique":    { "type": "boolean" },
        "maxLength": { "type": "integer", "minimum": 1 },
        "values": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "if": {
        "properties": { "type": { "const": "enum" } },
        "required": ["type"]
      },
      "then": {
        "required": ["values"]
      }
    },
    "Relation": {
      "type": "object",
      "required": ["type", "target"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["many-to-one", "one-to-many", "many-to-many", "one-to-one"]
        },
        "target":  { "type": "string" },
        "through": { "type": "string" }
      },
      "if": {
        "properties": { "type": { "const": "many-to-many" } },
        "required": ["type"]
      },
      "then": {
        "required": ["through"]
      }
    }
  }
}
