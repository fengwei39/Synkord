# Synkord Caddyfile
# 用法：替换 {YOUR_DOMAIN} 为你的实际域名（如 synkord.yourcompany.com）
# 首次启动会自动申请 Let's Encrypt 证书
#
# 本文件只在使用 `https` profile 时才会被加载：
#   docker compose --profile https up -d

# 全局选项
{
    email {$LETSENCRYPT_EMAIL}
    # admin off   # 生产环境禁用 Caddy admin API
}

# 主域名
{$SYNKORD_DOMAIN} {
    # 后端 API 反代
    reverse_proxy /api/* synkord:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {header.X-Forwarded-For}
        header_up X-Forwarded-Proto {scheme}
    }

    # MCP 端点
    reverse_proxy /mcp/* synkord:8000

    # 前端（独立部署在 CDN / OSS / Cloudflare Pages）
    # 不部署独立前端时，把这条改成 `file_server` + `root * /srv/frontend`
    reverse_proxy {$FRONTEND_ORIGIN} {
        header_up X-Forwarded-Proto {scheme}
    }

    # 安全头
    header {
        Strict-Transport-Security "max-age=31536000; includeSubdomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' wss: https:; font-src 'self' data:"
        -Server
    }

    # 访问日志
    log {
        output file /data/access.log {
            roll_size 100mb
            roll_keep 5
        }
    }
}

# HTTP → HTTPS 重定向
http://{$SYNKORD_DOMAIN} {
    redir https://{$SYNKORD_DOMAIN}{uri} permanent
}
