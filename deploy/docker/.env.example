# Synkord Docker 部署 - 环境变量
# 用法：cp .env.example .env  然后填实际值
# ⚠️ .env 不要提交到 Git！

# ----------------------------------------------------------------------------
# 镜像版本（改这个升级）
# 可选：latest / dev / vX.Y.Z / X.Y.Z
# ----------------------------------------------------------------------------
SYNKORD_IMAGE_TAG=0.3.0

# ----------------------------------------------------------------------------
# 必填：JWT 签名密钥
# 用 `openssl rand -hex 32` 生成 64 字符随机串
# 改了 = 所有用户重新登录
# ----------------------------------------------------------------------------
SYNKORD_JWT_SECRET=__REPLACE_WITH_64_HEX_CHARS__

# ----------------------------------------------------------------------------
# CORS 白名单（多个用逗号分隔；* 表示全开）
# 内部 / VPN 部署：填 * 即可
# HTTPS 部署：填前端域名，如 https://synkord.yourcompany.com
# ----------------------------------------------------------------------------
SYNKORD_CORS_ORIGINS=*

# ----------------------------------------------------------------------------
# 可选：时区
# ----------------------------------------------------------------------------
TZ=Asia/Shanghai

# ============================================================================
# 以下仅在使用 `https` profile 时需要：
#   docker compose --profile https up -d
# ============================================================================

# 必填：服务器域名（DNS A 记录指向本机 IP）
# SYNKORD_DOMAIN=synkord.yourcompany.com

# 必填：Let's Encrypt 邮箱（证书到期前会发提醒）
# LETSENCRYPT_EMAIL=ops@yourcompany.com

# 必填：前端域名（CDN / OSS / Cloudflare Pages 部署时填这个）
# 默认跟 SYNKORD_DOMAIN 一致；前端跟后端同源时填相同值即可
# FRONTEND_ORIGIN=https://synkord.yourcompany.com
