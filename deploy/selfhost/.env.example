# Synkord 自托管部署 - 环境变量模板
# 复制为 .env 并填入实际值：cp .env.example .env
# ⚠️ .env 不要提交到 Git！

# ----------------------------------------------------------------------------
# 必填：密钥（用 `openssl rand -hex 32` 生成）
# ----------------------------------------------------------------------------
JWT_SECRET=__REPLACE_WITH_64_HEX_CHARS__
MCP_TOKEN=__REPLACE_WITH_64_HEX_CHARS__

# ----------------------------------------------------------------------------
# 必填：域名
# ----------------------------------------------------------------------------
SYNKORD_DOMAIN=synkord.yourcompany.com
ALLOWED_ORIGINS=https://synkord.yourcompany.com
FRONTEND_ORIGIN=https://synkord.yourcompany.com

# ----------------------------------------------------------------------------
# 必填：Let's Encrypt 邮箱
# ----------------------------------------------------------------------------
LETSENCRYPT_EMAIL=ops@yourcompany.com

# ----------------------------------------------------------------------------
# 可选：时区（默认 UTC）
# ----------------------------------------------------------------------------
TZ=Asia/Shanghai
