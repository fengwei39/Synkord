{
  "$schema": "https://synkord.dev/schema/contract-v1.json",
  "pack": "auth-pack",
  "version": "1.0.0",
  "conventions": {
    "id_type": "uuid",
    "naming": {
      "db":   "snake_case",
      "api":  "camelCase",
      "java": "PascalCase",
      "go":   "PascalCase"
    },
    "timestamps": {
      "created_at": "datetime",
      "updated_at": "datetime"
    }
  },
  "entities": {
    "User": {
      "table": "users",
      "fields": {
        "id":         { "type": "uuid",     "primary": true },
        "email":      { "type": "string",   "maxLength": 255, "unique": true },
        "status":     { "type": "enum",     "values": ["active", "suspended"] },
        "created_at": { "type": "datetime" },
        "updated_at": { "type": "datetime" }
      },
      "relations": {
        "roles": {
          "type":    "many-to-many",
          "target":  "Role",
          "through": "user_roles"
        }
      }
    },
    "Role": {
      "table": "roles",
      "fields": {
        "id":         { "type": "uuid",   "primary": true },
        "name":       { "type": "string", "maxLength": 100, "unique": true },
        "created_at": { "type": "datetime" },
        "updated_at": { "type": "datetime" }
      }
    }
  }
}
